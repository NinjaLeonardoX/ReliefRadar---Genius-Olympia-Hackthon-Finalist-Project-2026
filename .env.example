# DisasterCompass — environment variables
#
# Copy to `.env` (gitignored) and fill in only the keys you want to test live.
# EVERY flag defaults OFF. With all flags off / no keys, the app runs the
# bulletproof offline demo (seed data) — this is the judged demo configuration.
# Flip a single flag on to show a live "wow"; each one independently falls back
# to seed data if its source is down.
#
# For deploys, set the same vars in Vercel → Project → Settings → Env Vars.

# --- Feature flags (client-readable, inlined at build time) ---
# Set to "true" to enable. Omit / "false" keeps the offline demo.
VITE_LIVE_WEATHER=false      # Open-Meteo current weather (keyless)
VITE_LIVE_TILES=false        # MapTiler basemap (needs VITE_MAPTILER_KEY below)
VITE_LIVE_ROUTING=false      # OpenRouteService routing (needs ORS_API_KEY below)
VITE_LIVE_EARTHQUAKES=false  # USGS earthquakes feed (keyless)
VITE_LIVE_ALERTS=false       # NWS active alerts (keyless, US)

# --- Map tile key (CLIENT-side: the browser sends it) ---
# Free tier at https://www.maptiler.com/. IMPORTANT: restrict this key to your
# deployed domain(s) in the MapTiler dashboard, since it ships to the browser.
VITE_MAPTILER_KEY=

# --- Routing key (SERVER-side only: never prefix with VITE_) ---
# Free token at https://openrouteservice.org/dev/. Read only inside the
# createServerFn handler via process.env — never exposed to the browser.
ORS_API_KEY=
