# DisasterCompass — live data integration
#
# Copy this file to `.env` and adjust as needed. `.env` is gitignored.
# ALL feature flags default to FALSE. With everything unset/false, the app runs
# entirely on in-memory seed data (the offline demo) and is byte-for-byte
# identical to the no-config build. Flip a flag to `true` to enable that live
# source once its phase is implemented.

# --- Feature flags (booleans: true / false) ---
VITE_LIVE_EARTHQUAKES=false   # Phase 1 — USGS earthquakes (keyless)
VITE_LIVE_WEATHER=false        # Phase 2 — Open-Meteo weather + elevation (keyless)
VITE_LIVE_ALERTS=false         # Phase 3 — NWS active alerts (keyless, US)
VITE_LIVE_TILES=false          # Phase 4 — MapTiler/Stadia basemap (needs MAPTILER_KEY)
VITE_LIVE_ROUTING=false        # Phase 5 — OpenRouteService routing (needs OPENROUTESERVICE_KEY)
VITE_LIVE_INFRA=false          # Phase 6 — Overpass shelters/buildings (keyless)
VITE_LIVE_FIRE=false           # Phase 7 — NASA FIRMS wildfire (needs NASA_FIRMS_KEY)

# --- API keys (SERVER-SIDE ONLY) ---
# No VITE_ prefix: these are read inside createServerFn handlers via
# process.env and are never exposed to the client bundle. Leave blank until the
# relevant phase; a keyed source no-ops (falls back to seed) when its key is
# absent.
MAPTILER_KEY=
OPENROUTESERVICE_KEY=
NASA_FIRMS_KEY=
